# Loaded by `vite --mode test` (the e2e server). Points "Supabase" at the app's
# own origin so PostgREST requests are same-origin and Playwright can intercept
# them (see e2e/fixtures.ts) — no real network, no real project touched.
VITE_SUPABASE_URL=http://localhost:4173
VITE_SUPABASE_ANON_KEY=test-anon-key
