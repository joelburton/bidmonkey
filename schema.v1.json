{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bidmonkey/schema/v1",
  "title": "bidmonkey problem content (v1)",
  "description": "Validates the JSONB columns of `problems`. The root validates an object {deal, auction, play}; the app may also validate a single column via $ref to #/$defs/deal, #/$defs/auction, or #/$defs/play.",

  "type": "object",
  "required": ["deal", "auction"],
  "additionalProperties": false,
  "properties": {
    "deal":    { "$ref": "#/$defs/deal" },
    "auction": { "$ref": "#/$defs/auction" },
    "play":    { "$ref": "#/$defs/play" }
  },

  "$defs": {
    "seat":    { "type": "string", "enum": ["N", "E", "S", "W"] },

    "bid":     { "type": "string", "pattern": "^(?:[1-7](?:C|D|H|S|N|NT)|P|X|XX)$",
                 "description": "A call: a bid (level+strain, NT as N or NT), P, X, or XX." },

    "card":    { "type": "string", "pattern": "^[SHDC][AKQJT2-9]$",
                 "description": "Suit letter + rank; T = ten." },

    "holding": { "type": "string", "pattern": "^[AKQJT2-9]*$",
                 "description": "Ranks in one suit, high to low; empty string = void." },

    "hand": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "S": { "$ref": "#/$defs/holding" },
        "H": { "$ref": "#/$defs/holding" },
        "D": { "$ref": "#/$defs/holding" },
        "C": { "$ref": "#/$defs/holding" }
      }
    },

    "deal": {
      "type": "object",
      "description": "Each seat optional (a bidding quiz may show only one hand).",
      "additionalProperties": false,
      "properties": {
        "N": { "$ref": "#/$defs/hand" },
        "E": { "$ref": "#/$defs/hand" },
        "S": { "$ref": "#/$defs/hand" },
        "W": { "$ref": "#/$defs/hand" }
      }
    },

    "bidQuestion": {
      "type": "object",
      "required": ["id", "choiceType", "answer"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "minLength": 1 },
        "choiceType":  { "enum": ["multiple_choice", "enter_bid"] },
        "prompt":      { "type": "string" },
        "answer":      { "$ref": "#/$defs/bid" },
        "options":     { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/bid" } },
        "accept":      { "type": "array", "items": { "$ref": "#/$defs/bid" },
                         "description": "Extra acceptable answers beyond `answer` (enter_bid)." },
        "explanation": { "type": "string" }
      },
      "allOf": [
        { "if":   { "properties": { "choiceType": { "const": "multiple_choice" } } },
          "then": { "required": ["options"] } },
        { "if":   { "properties": { "choiceType": { "const": "enter_bid" } } },
          "then": { "not": { "required": ["options"] } } }
      ]
    },

    "cardQuestion": {
      "type": "object",
      "required": ["id", "choiceType", "answer"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "minLength": 1 },
        "choiceType":  { "enum": ["multiple_choice", "enter_card"] },
        "prompt":      { "type": "string" },
        "answer":      { "$ref": "#/$defs/card" },
        "options":     { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/card" } },
        "accept":      { "type": "array", "items": { "$ref": "#/$defs/card" } },
        "explanation": { "type": "string" }
      },
      "allOf": [
        { "if":   { "properties": { "choiceType": { "const": "multiple_choice" } } },
          "then": { "required": ["options"] } },
        { "if":   { "properties": { "choiceType": { "const": "enter_card" } } },
          "then": { "not": { "required": ["options"] } } }
      ]
    },

    "auction": {
      "type": "array",
      "description": "Ordered calls. Seat is implicit: element 0 is the dealer, then clockwise. A question's `answer` is the call that continues the auction.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "call":     { "$ref": "#/$defs/bid" },
          "question": { "$ref": "#/$defs/bidQuestion" }
        },
        "oneOf": [
          { "required": ["call"] },
          { "required": ["question"] }
        ]
      }
    },

    "play": {
      "type": "array",
      "description": "Tricks in order. Seat is explicit on each play (the leader varies).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cards"],
        "properties": {
          "cards": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["seat"],
              "properties": {
                "seat":     { "$ref": "#/$defs/seat" },
                "card":     { "$ref": "#/$defs/card" },
                "question": { "$ref": "#/$defs/cardQuestion" }
              },
              "oneOf": [
                { "required": ["card"] },
                { "required": ["question"] }
              ]
            }
          }
        }
      }
    }
  }
}
