# Loaded by `vite --mode test` (the e2e server). Points at the LOCAL Supabase
# stack (custom ports from supabase/config.toml), so e2e runs against real
# PostgREST + RLS. Requires `supabase start` (repo root) to be running; the
# Playwright global-setup runs `supabase db reset` to a known seed before tests.
# This is the local publishable key from `supabase status` — local-only, not a
# secret. If auth fails, re-check it against `supabase status`.
VITE_SUPABASE_URL=http://127.0.0.1:54331
VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
