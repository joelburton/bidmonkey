# Copy to .env and fill in from your Supabase project (Settings → API).
# Safe to ship: the anon key is public by design; RLS governs what it can do.
# Vite only exposes vars prefixed VITE_ to the browser.

# e.g. https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=

# the long "anon" / "public" key from Settings → API → Project API keys
VITE_SUPABASE_ANON_KEY=
